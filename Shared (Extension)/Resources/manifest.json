{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.1.1",
  "icons": {
    "16": "images/toolbar-blue-16.png",
    "32": "images/toolbar-blue-32.png",
    "48": "images/toolbar-blue-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/toolbar-gray-16.png",
      "32": "images/toolbar-gray-32.png",
      "48": "images/toolbar-gray-48.png",
      "128": "images/toolbar-gray-128.png"
    }
  },
  "options_ui": {
    "page": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "freedirect_static_defaults",
        "enabled": true,
        "path": "static_rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "nativeMessaging",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "redirect-current": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R",
        "ios": "Alt+Shift+R"
      },
      "description": "__MSG_redirectCurrent__"
    },
    "reverse-current": {
      "suggested_key": {
        "default": "Alt+Shift+O",
        "mac": "Alt+Shift+O",
        "ios": "Alt+Shift+O"
      },
      "description": "__MSG_reverseCurrent__"
    },
    "bypass-current": {
      "suggested_key": {
        "default": "Alt+Shift+B",
        "mac": "Alt+Shift+B",
        "ios": "Alt+Shift+B"
      },
      "description": "__MSG_bypassCurrent__"
    }
  },
  "default_locale": "en"
}
